# ===================================================================
# 🚀 QUICK START - MINIMUM REQUIRED FIELDS
# ===================================================================
# Fill in these 3 fields to get your bot running quickly!
# Everything else can be configured later.

# ! [REQUIRED] 1️⃣ LICENSE KEY
# Get your license key by joining Kythia's Discord server
# 🔗 https://dsc.gg/kythia
LICENSE_KEY=""

# ! [REQUIRED] 2️⃣ DISCORD BOT TOKEN
# Get this from Discord Developer Portal > Your App > Bot > Token
# 🔗 https://discord.com/developers/applications
DISCORD_BOT_TOKEN=""

# ! [REQUIRED] 3️⃣ DISCORD CLIENT ID
# Get this from Discord Developer Portal > Your App > General Information > Application ID
# 🔗 https://discord.com/developers/applications
DISCORD_BOT_CLIENT_ID=""

# ✅ That's it for basic setup! Save this file and start your bot.
# The bot will use SQLite by default (no additional database setup needed).


# ===================================================================
# 📦 DATABASE CONFIGURATION (Optional - SQLite is used by default)
# ===================================================================

# Current Setting: SQLite (No additional setup needed!)
# The database file will be created automatically as "kythia.sqlite"
DB_DRIVER=sqlite
DB_NAME=kythia.sqlite

# ─────────────────────────────────────────────────────────────────
# 💡 Want to use a different database? Follow these steps:
# ─────────────────────────────────────────────────────────────────
#
# STEP 1: Install the database driver
# ┌───────────┬────────────────────────────────────┐
# │ Database  │ Installation Command               │
# ├───────────┼────────────────────────────────────┤
# │ MySQL     │ npm install mysql2                 │
# │ MariaDB   │ npm install mariadb                │
# │ PostgreSQL│ npm install pg pg-hstore           │
# │ MSSQL     │ npm install tedious                │
# │ SQLite    │ npm install sqlite3 (default)      │
# └───────────┴────────────────────────────────────┘
#
# STEP 2: Uncomment and fill in the settings below for your database
#
# DB_DRIVER=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=kythia
# DB_USER=root
# DB_PASSWORD=your_password
#
# ─────────────────────────────────────────────────────────────────
# Advanced Database Options (Usually not needed)
# ─────────────────────────────────────────────────────────────────
#
# For SQLite only - custom storage path:
# DB_STORAGE_PATH=db/database.sqlite
#
# For MySQL/MariaDB - Unix socket connection:
# DB_SOCKET_PATH=/cloudsql/your-instance-connection-name
#
# For MSSQL - Dialect options (JSON format):
# DB_DIALECT_OPTIONS={"options":{"encrypt":true,"trustServerCertificate":true}}


# ===================================================================
# ⚡ REDIS CACHE 
# ===================================================================
# ! [REQUIRED]
# Leave empty if you don't have Redis installed
# Example: redis://localhost:6379
# For multiple instances, separate with commas
REDIS_URLS=""


# ===================================================================
# 🔧 ADDITIONAL DISCORD SETTINGS
# ===================================================================

# ! [REQUIRED for Dashboard] Discord Client Secret
# Required for OAuth2 features like the web dashboard
# Get this from Discord Developer Portal > Your App > OAuth2 > Client Secret
# 🔗 https://discord.com/developers/applications
DISCORD_BOT_CLIENT_SECRET=""


# ===================================================================
# 📊 MONITORING & LOGGING (Optional)
# ===================================================================

# ? [OPTIONAL] Sentry DSN - For advanced error tracking and monitoring
# 🔗 https://sentry.io
SENTRY_DSN=""

# ? [OPTIONAL] Webhook for bot invite/leave notifications
WEBHOOK_GUILD_INVITE_LEAVE=""

# ? [OPTIONAL] Webhook for critical error logs
WEBHOOK_ERROR_LOGS=""


# ===================================================================
# 🎵 MUSIC ADDON CONFIGURATION
# ===================================================================
# Required only if you want to use music features

# ─────────────────────────────────────────────────────────────────
# Lavalink Server Configuration
# ─────────────────────────────────────────────────────────────────
# All LAVALINK_* fields must have the same number of items (separated by commas)
#
# Example for 2 nodes:
# LAVALINK_HOSTS="localhost,lavalink.example.com"
# LAVALINK_PORTS="2333,80"
# LAVALINK_PASSWORDS="youshallnotpass,anothersecret"
# LAVALINK_SECURES="false,true"

# ! [REQUIRED for Music Addon]
LAVALINK_HOSTS=""
LAVALINK_PORTS=""
LAVALINK_PASSWORDS=""
LAVALINK_SECURES=""

# ─────────────────────────────────────────────────────────────────
# Spotify Integration (Optional - For Spotify track support)
# ─────────────────────────────────────────────────────────────────
# ? [OPTIONAL] For Spotify track support
# 🔗 https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""

# ─────────────────────────────────────────────────────────────────
# Audd.io API (Optional - For lyrics feature)
# ─────────────────────────────────────────────────────────────────
# ? [OPTIONAL] For lyrics feature
# 🔗 https://audd.io
AUDD_API_KEY=""


# ===================================================================
# 🤖 AI ADDON CONFIGURATION
# ===================================================================
# Required only if you want to use AI chat features

# ! [REQUIRED for AI Addon] Google Gemini API Key(s)
# Can be a single key or multiple keys separated by commas
# 🔗 https://aistudio.google.com/app/apikey
#
# Example: GEMINI_API_KEYS="key1,key2,key3"
GEMINI_API_KEYS=""


# ===================================================================
# 🌐 DASHBOARD / API ADDON CONFIGURATION
# ===================================================================
# Required only if you want to enable the web dashboard

# ! [REQUIRED for Dashboard] API Secret
# A long, random secret for signing session cookies
# Generate one here: https://www.lastpass.com/features/password-generator
# Recommended: 32+ characters, mix of letters, numbers, and symbols
API_SECRET=""

# ! [REQUIRED for Dashboard] API URL
# The FULL public URL used to access the dashboard
# This MUST MATCH EXACTLY one of the "Redirect URIs" in Discord Developer Portal
# Examples:
#   - Localhost: http://localhost:3000
#   - VPS/IP: http://YOUR_IP:3000
#   - Domain: https://yourdomain.com
#   - Domain with Port: https://panel.yourdomain.com:2705
API_URL=""

# ? [OPTIONAL] API Port - The port your dashboard will run on
# Default: 3000
# ⚠️  Make sure this port is open in your firewall/hosting panel!
API_PORT=3000

# FOR SECURITY, ALLOWED ORIGINS MUST MATCH WITH YOUR DASHBOARD URL
API_ALLOWED_ORIGIN="http://localhost:8000,http://127.0.0.1:8000"

# ─────────────────────────────────────────────────────────────────
# 🔐 IMPORTANT - OAuth2 Redirect URI Setup
# ─────────────────────────────────────────────────────────────────
# After enabling the dashboard, you MUST configure the redirect URI:
#
# 1. Go to Discord Developer Portal > Your App > OAuth2
#    🔗 https://discord.com/developers/applications
# 2. Under "Redirects", click "Add Redirect" and add ONE of these:
#    • Localhost: http://localhost:3000/auth/discord/callback
#    • VPS/IP: http://YOUR_IP:3000/auth/discord/callback
#    • Domain: https://yourdomain.com/auth/discord/callback
# 3. Click "Save Changes"


# ===================================================================
# 🗳️ TOP.GG INTEGRATION (Optional - For vote tracking)
# ===================================================================
# Required only if you want vote-locked features

# ! [REQUIRED for Vote Features] Top.gg API credentials
# 🔗 https://top.gg/bot/YOUR_BOT_ID/dashboard/integrations
TOPGG_API_KEY=""
TOPGG_AUTH_TOKEN=""

# ? [OPTIONAL] Discord webhook for vote logs
WEBHOOK_VOTE_LOGS=""

# ⚠️  IMPORTANT: Webhook Configuration
# Set the Top.gg webhook URL to: https://YOUR_DOMAIN/api/webhooks/topgg
# Examples:
#   - https://example.com/api/webhooks/topgg
#   - https://panel.example.com:2705/api/webhooks/topgg


# ===================================================================
# 🛠️ UTILITY ADDONS
# ===================================================================

# ─────────────────────────────────────────────────────────────────
# Currency Conversion (Core Addon)
# ─────────────────────────────────────────────────────────────────
# ? [OPTIONAL] ExchangeRate-API key for currency conversion features
# 🔗 https://manage.exchangeratesapi.io/signup/free
EXCHANGERATE_API=""

# ─────────────────────────────────────────────────────────────────
# Image Storage (Image Addon)
# ─────────────────────────────────────────────────────────────────
# ! [REQUIRED for Image Addon] Kythia Storage Server
# 🔗 https://github.com/kenndeclouv/kythia-storage
KYTHIA_IMAGE_STORAGE_URL=""
KYTHIA_IMAGE_STROAGE_API_KEY=""


# ===================================================================
# ☁️ CLOUDFLARE SUBDOMAIN MANAGEMENT (Pro Addon)
# ===================================================================
# Required only if you want to offer custom subdomains to users

# ! [REQUIRED for Pro Addon] Cloudflare API Token (NOT your Global API Key!)
# Create a token with DNS:Edit permissions
# 🔗 https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=""

# ! [REQUIRED for Pro Addon] Cloudflare Zone ID
# Found in Cloudflare Dashboard > Your Domain > Overview (right sidebar)
CLOUDFLARE_ZONE_ID=""

# ! [REQUIRED for Pro Addon] Your root domain (e.g., kyth.me)
CLOUDFLARE_DOMAIN=""

# ─────────────────────────────────────────────────────────────────
# Discord Quest Notification
# ! WARNING
# host your own quest api
# see my repo https://github.com/kenndeclouv/kythia-quest-api
# ! IMPORTANT NOTE: the quest api need user token to work
# and using user token is violation of discord's terms of service
# so it's dangerously to use it
# ─────────────────────────────────────────────────────────────────
# ! [REQUIRED for Quest Addon]
# 🔗 https://github.com/kenndeclouv/kythia-quest-api
QUEST_API_URLS="" # seperate with comma



# ===================================================================
# 🔗 INTERNAL FEATURES (Kythia Official Only)
# ===================================================================
# These features are for official Kythia instances only
# Leave empty unless you have official access

# ─────────────────────────────────────────────────────────────────
# Global Chat (Internal Feature)
# ─────────────────────────────────────────────────────────────────
GLOBAL_CHAT_API_URL=""
GLOBAL_CHAT_API_KEY=""

# ─────────────────────────────────────────────────────────────────
# Global Voice (Internal Feature)
# ─────────────────────────────────────────────────────────────────
GLOBAL_VOICE_API_URL=""
GLOBAL_VOICE_API_KEY=""


# ===================================================================
# 🎉 CONFIGURATION COMPLETE!
# ===================================================================
#
# Next Steps:
#   1. Save this file as '.env' (remove 'example.' from the filename)
#   2. Start your bot with: npm start
#   3. If you see errors, check that you filled in the required fields
#   4. Join our Discord for help: https://dsc.gg/kythia
